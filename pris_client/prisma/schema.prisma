// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// --- ENUMS ---
enum Role {
  WORKER
  VERIFIER
  ADVOCATE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  DISCREPANCY
  UNVERIFIABLE
}

enum PostCategory {
  PLATFORM_COMPLAINT
  SUPPORT_REQUEST
}

enum PostStatus {
  OPEN
  ESCALATED
  RESOLVED
}

enum WorkerCategory {
  RIDE_HAILING
  FOOD_DELIVERY
  FREELANCE_DESIGNER
  DOMESTIC_WORKER
}

// Add to your ENUMS
enum FlagType {
  UNUSUAL_DEDUCTION
  SUDDEN_INCOME_DROP
}

// --- MODELS ---

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String
  role           Role
  // Specifically for Verifiers. Workers/Advocates default to APPROVED.
  approvalStatus ApprovalStatus @default(PENDING) 
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  workerProfile  WorkerProfile?
  shiftLogs      ShiftLog[]     @relation("WorkerLogs")
  verifiedLogs   ShiftLog[]     @relation("VerifierLogs")
  grievancePosts GrievancePost[]
  vulnerabilityFlags VulnerabilityFlag[]
}

model WorkerProfile {
  id              String         @id @default(uuid())
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        WorkerCategory
  cityZone        String         // Required for Advocate Analytics & City-wide median comparison
  defaultCurrency String         @default("PKR") // Supports multi-currency constraint
}

model Platform {
  id        String     @id @default(uuid())
  name      String     @unique // e.g., Uber, Foodpanda, Upwork
  isActive  Boolean    @default(true) // Advocate can soft-delete/disable
  createdAt DateTime   @default(now())
  
  shiftLogs ShiftLog[]
  complaints GrievancePost[]
}

model ShiftLog {
  id                 String             @id @default(uuid())
  workerId           String
  worker             User               @relation("WorkerLogs", fields: [workerId], references: [id], onDelete: Cascade)
  platformId         String
  platform           Platform           @relation(fields: [platformId], references: [id])
  
  date               DateTime
  hoursWorked        Float
  grossEarned        Float
  platformDeductions Float
  netReceived        Float
  currency           String             @default("PKR")
  
  screenshotUrl      String?            // Supabase Storage URL
  status             VerificationStatus @default(PENDING)
  
  verifierId         String?            // The Verifier who reviewed it
  verifier           User?              @relation("VerifierLogs", fields: [verifierId], references: [id])
  verifierNotes      String?            // Comments from verifier on discrepancy
  
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([workerId, date])
}

model GrievancePost {
  id          String       @id @default(uuid())
  workerId    String
  worker      User         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  platformId  String?      // Optional: if complaint is platform-specific
  platform    Platform?    @relation(fields: [platformId], references: [id])
  
  category    PostCategory
  description String
  rateIntel   Float?       // Optional: for sharing rate drops/changes
  tags        String[]     // Postgres string array for easy filtering ("unfair_deactivation", etc.)
  status      PostStatus   @default(OPEN)
  
  clusterId   String?      // Advocate tags similar complaints together
  cluster     GrievanceCluster? @relation(fields: [clusterId], references: [id])
  
  createdAt   DateTime     @default(now())
}

model GrievanceCluster {
  id          String          @id @default(uuid())
  name        String          // e.g., "Uber Islamabad Commission Drop Nov"
  createdAt   DateTime        @default(now())
  posts       GrievancePost[]
}


// Add to your MODELS
model VulnerabilityFlag {
  id          String   @id @default(uuid())
  workerId    String
  worker      User     @relation(fields: [workerId], references: [id], onDelete: Cascade)
  
  type        FlagType
  explanation String   // The human-readable explanation generated by FastAPI
  isResolved  Boolean  @default(false) // Allows Advocate to clear the flag
  
  createdAt   DateTime @default(now())

  @@index([workerId])
  @@index([type])
}